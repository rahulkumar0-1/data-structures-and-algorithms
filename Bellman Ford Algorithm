vector<int> bellman_ford(int V, vector<vector<int>>& edges, int S) {
		vector<int> dist(V, 1e8);
		dist[S] = 0;
//N-1 relaxation to find the shortest distance from source
		for (int i = 0; i < V - 1; i++) {
			for (auto it : edges) {
				int u = it[0]; //Starting point of the edge
				int v = it[1]; //Ending point of the edge
				int wt = it[2]; //Edge weight
				if (dist[u] != 1e8 && dist[u] + wt < dist[v]) {
					dist[v] = dist[u] + wt;
				}
			}
		}
		// Nth relaxation to check negative cycle
		for (auto it : edges) {
			int u = it[0];
			int v = it[1];
			int wt = it[2];
// this codition will tell you that is negative cycle exist or not
			if (dist[u] != 1e8 && dist[u] + wt < dist[v]) {
				return { -1};
			}
		}

//negative cycle does not exist then we return the result
		return dist;
	}
};
